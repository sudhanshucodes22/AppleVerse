# ─── AppleVerse API — Environment Configuration ────────────────────────
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# Server
PORT=3001
NODE_ENV=development

# JWT Secrets — generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_ACCESS_SECRET=your_64_byte_hex_access_secret_here
JWT_REFRESH_SECRET=your_64_byte_hex_refresh_secret_here

# JWT Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# bcrypt Cost Factor (12 recommended for production, 10 for dev speed)
BCRYPT_ROUNDS=12

# Rate Limiting
AUTH_RATE_LIMIT=10
API_RATE_LIMIT=60

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
